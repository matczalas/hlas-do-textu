# Volitelný .env soubor pro dev (běžně se klíč zadává v UI a ukládá do keyring)
# Zkopíruj na .env, vyplň klíč, a aplikace ho během dev použije přednostně.

GEMINI_API_KEY=

# Volitelný override Ollama endpointu (default http://localhost:11434)
OLLAMA_BASE_URL=

# Volitelný override Whisper modelu pro dev (default medium)
WHISPER_MODEL=
